.yp-drop-icon { font-size: 40px; margin-bottom: 12px; }
.yp-drop-main { font-family: 'Barlow', sans-serif; font-size: 16px; color: var(--yp-text); margin: 0 0 6px; font-weight: 500; }
.yp-drop-sub { font-family: 'Barlow', sans-serif; font-size: 13px; color: var(--yp-text3); margin: 0; }
.yp-drop-link { color: var(--yp-gold); cursor: pointer; text-decoration: underline; }

/* ── File info ── */
.yp-file-info {
  display: flex; align-items: center; gap: 14px;
  background: var(--yp-card-inner); border: 1px solid var(--yp-border);
  border-radius: 12px; padding: 14px 18px;
}
.yp-file-icon { font-size: 24px; }
.yp-file-details { flex: 1; }
.yp-file-name { display: block; font-family: 'Barlow', sans-serif; font-size: 14px; color: var(--yp-text); font-weight: 500; }
.yp-file-rows { display: block; font-family: 'Barlow', sans-serif; font-size: 12px; color: var(--yp-text2); margin-top: 2px; }
.yp-file-remove {
  background: none; border: 1px solid var(--yp-border); border-radius: 8px;
  color: var(--yp-text3); font-size: 14px; padding: 6px 10px; cursor: pointer;
  transition: color 0.2s, border-color 0.2s;
}
.yp-file-remove:hover { color: var(--yp-red); border-color: var(--yp-red); }

/* ── Progress bar ── */
.yp-progress-wrap { margin-top: 16px; }
.yp-progress-bar { height: 6px; background: var(--yp-card-inner); border-radius: 4px; overflow: hidden; }
.yp-progress-fill { height: 100%; background: var(--yp-gold); border-radius: 4px; transition: width 0.3s ease; width: 0%; }
.yp-progress-text { display: block; font-family: 'Barlow', sans-serif; font-size: 12px; color: var(--yp-text2); margin-top: 6px; }

/* ── Ticket row ── */
.yp-ticket-row { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
.yp-ticket-label { display: flex; align-items: center; gap: 6px; }
.yp-ticket-prefix { font-family: 'Barlow', sans-serif; font-size: 16px; font-weight: 600; color: var(--yp-text2); }
.yp-ticket-input { width: 130px; }

/* ── Inputs ── */
.yp-input {
  background: var(--yp-card-inner); border: 1px solid var(--yp-border);
  border-radius: 10px; color: var(--yp-text); font-family: 'Barlow', sans-serif;
  padding: 10px 14px; font-size: 15px; transition: border-color 0.2s;
}
.yp-input:focus { border-color: var(--yp-gold); outline: none; box-shadow: 0 0 0 3px rgba(201,168,76,0.15); }

.yp-select {
