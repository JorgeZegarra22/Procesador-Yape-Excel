  letter-spacing: 0.08em;
  margin-top: 8px;
  font-family: 'Barlow', sans-serif;
  line-height: 1.3;
}

/* ── Table ── */
.yp-table-note { font-family: 'Barlow', sans-serif; font-size: 12px; color: var(--yp-text3); margin-bottom: 10px; }
.yp-table-wrap { border: 1px solid var(--yp-border); border-radius: 12px; overflow: hidden; overflow-x: auto; }
.yp-table { width: 100%; border-collapse: collapse; }
.yp-table th {
  background: #0D1520; color: var(--yp-text2); font-size: 11px; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.08em; padding: 10px 14px;
  border-bottom: 1px solid var(--yp-border); text-align: left;
  font-family: 'Barlow', sans-serif;
}
.yp-table td {
  padding: 10px 14px; color: var(--yp-text); font-size: 13px;
  border-bottom: 1px solid var(--yp-border); font-family: 'Barlow', sans-serif;
}
.yp-table tr:last-child td { border-bottom: none; }
.yp-table tr:hover td { background: var(--yp-card-inner); }

/* ── Chips ── */
