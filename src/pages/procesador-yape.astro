}
.yp-btn-gold:hover { background: var(--yp-gold-h); }
.yp-btn-gold:active { transform: scale(0.97); }
.yp-btn-gold:disabled { opacity: 0.5; cursor: not-allowed; }

.yp-btn-copy { width: 100%; margin-top: 20px; padding: 16px 28px; font-size: 15px; }

/* ── Stats grid ── */
.yp-stats {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16px;
  margin-bottom: 28px;
}
.yp-stat {
  background: rgba(26, 34, 53, 0.45);
  border: 1px solid rgba(201, 168, 76, 0.15);
  border-radius: 16px;
  padding: 18px 12px;
  text-align: center;
  backdrop-filter: blur(8px);
  display: flex;
  flex-direction: column;
